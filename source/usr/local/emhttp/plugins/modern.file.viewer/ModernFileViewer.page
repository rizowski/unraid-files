<?php
/**
 * Modern File Viewer - asset injector.
 *
 * Unraid emits the body of every "Buttons" page (Menu="Buttons:NN") into the
 * <head> of EVERY webGUI page, including the file manager's /Shares/Browse view
 * (see emhttp/plugins/dynamix/include/DefaultPageLayout.php, which loops over
 * find_pages('Buttons')). That is the supported, update-safe way to get our
 * <script>/<link> onto the Browse page without patching any built-in file.
 *
 * We do NOT want a visible toolbar button, so Link is set (a non-empty Link
 * makes Navigation/Main.php render an inert <div> instead of a clickable icon,
 * and avoids needing a global function named after this page).
 *
 * Our JavaScript only acts where the global fileEdit(id) exists (the Browse
 * page), so loading on other pages is inert.
 *
 * ACE lives in core dynamix at /plugins/dynamix/javascript/ace and is already
 * present on the Browse page; we reuse it rather than shipping a second copy.
 */
$mfv_var  = @parse_ini_file('/usr/local/emhttp/state/var.ini') ?: [];
$mfv_csrf = $mfv_var['csrf_token'] ?? '';
$mfv_ace  = '/plugins/dynamix/javascript/ace/ace.js';
$mfv_base = '/plugins/modern.file.viewer';

// Server-side hint for the active Unraid theme (black/gray = dark, white/azure =
// light). This is a fallback; mfv-viewer.js prefers the <html class="Theme--...">
// set by DefaultPageLayout. Emit null when unknown so the client default applies.
$mfv_theme = isset($display['theme']) ? strtok((string) $display['theme'], '-') : '';
$mfv_dark  = $mfv_theme === '' ? null : in_array($mfv_theme, ['black', 'gray'], true);
?>
<link rel="stylesheet" href="<?=$mfv_base?>/styles/mfv-viewer.css">
<script>
window.MFV = {
  base: "<?=$mfv_base?>",
  csrf: "<?=htmlspecialchars($mfv_csrf, ENT_QUOTES)?>",
  acePath: "/plugins/dynamix/javascript/ace",
  dark: <?= $mfv_dark === null ? 'null' : ($mfv_dark ? 'true' : 'false') ?>
};
</script>
<?php if (is_file('/usr/local/emhttp' . $mfv_ace)): ?>
<script src="<?=$mfv_ace?>"></script>
<?php endif; ?>
<script src="<?=$mfv_base?>/javascript/mfv-detect.js"></script>
<script src="<?=$mfv_base?>/javascript/mfv-viewer.js"></script>
